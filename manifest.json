{
  "manifest_version": 3,
  "name": "ResellKit Pro",
  "short_name": "ResellKit",
  "version": "2.2.0",
  "description": "Extension Chrome MV3 pour revendeurs pros — calculateur de profit, portfolio, alertes drops, Roland-Garros mode, Captcha Inbox. 100% legal, 0 bypass.",
  "author": "ResellKit",
  "minimum_chrome_version": "120",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ResellKit Pro"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "sidePanel",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.nike.com/*",
        "https://www.adidas.com/*",
        "https://www.footlocker.com/*",
        "https://www.jdsports.fr/*",
        "https://stockx.com/*",
        "https://www.goat.com/*",
        "https://www.grailed.com/*",
        "https://www.ebay.fr/*",
        "https://www.ebay.com/*",
        "https://www.ticketmaster.fr/*",
        "https://www.ticketmaster.com/*",
        "https://www.fnactickets.com/*",
        "https://www.rollandgarros.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background/sw.js"
  },
  "commands": {
    "quick-add": {
      "suggested_key": {
        "default": "Alt+A"
      },
      "description": "Quick add item"
    },
    "open-sidepanel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Open Side Panel"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
