{
  "manifest_version": 3,
  "name": "ResellKit Pro",
  "short_name": "ResellKit",
  "version": "2.1.0",
  "description": "Extension Chrome MV3 pour revendeurs pros — calculateur de profit, portfolio, alertes drops, Roland-Garros mode, Captcha Inbox. 100% legal, 0 bypass.",
  "author": "ResellKit",
  "homepage_url": "https://resellkit.pro",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ResellKit Pro",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "sidePanel",
    "activeTab",
    "tabs",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.nike.com/*",
        "https://www.adidas.com/*",
        "https://www.footlocker.com/*",
        "https://www.jdsports.fr/*",
        "https://stockx.com/*",
        "https://www.goat.com/*",
        "https://www.grailed.com/*",
        "https://www.ebay.fr/*",
        "https://www.ebay.com/*",
        "https://www.vinted.fr/*",
        "https://www.vinted.com/*",
        "https://www.leboncoin.fr/*",
        "https://www.ticketmaster.fr/*",
        "https://www.ticketmaster.com/*",
        "https://www.fnac.com/*",
        "https://www.stubhub.com/*",
        "https://www.viagogo.com/*",
        "https://www.seatgeek.com/*",
        "https://www.rolandgarros.com/*",
        "https://billetterie.fft.fr/*",
        "https://www.fft.fr/*",
        "https://travel.rolandgarros.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background/sw.js",
    "type": "module"
  },
  "options_page": "options/options.html",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "Ouvrir ResellKit"
    },
    "add-to-portfolio": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Ajouter au portfolio"
    },
    "create-alert": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "Creer une alerte"
    },
    "open-sidepanel": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Ouvrir le Side Panel"
    },
    "toggle-overlay": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Afficher/masquer l overlay"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline';"
  }
}
