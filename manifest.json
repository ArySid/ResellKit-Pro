{"manifest_version": 3,"name": "ResellKit Pro","short_name": "ResellKit","version": "2.1.0","description": "Extension Chrome MV3 pour revendeurs pros — calculateur de profit, portfolio, alertes drops, Roland-Garros mode, Captcha Inbox. 100% legal, 0 bypass.","author": "ResellKit","homepage_url": "https://resellkit.pro","icons": {"16": "assets/icon16.png","48": "assets/icon48.png","128": "assets/icon128.png"},"action": {"default_popup": "popup/popup.html","default_title": "ResellKit Pro","default_icon": {"16": "assets/icon16.png","48": "assets/icon48.png","128": "assets/icon128.png"}},"side_panel": {"default_path": "sidepanel/sidepanel.html"},"permissions": ["storage","alarms","notifications","sidePanel","activeTab","tabs","contextMenus","scripting"],"host_permissions": ["https://*/*","http://localhost/*"],"content_scripts": [{"matches": ["https://www.nike.com/*","https://www.adidas.com/*","https://www.footlocker.com/*","https://www.jdsports.fr/*","https://stockx.com/*","https://www.goat.com/*","https://www.grailed.com/*","https://www.ebay.fr/*","https://www.ebay.com/*","https://www.ticketmaster.fr/*","https://www.ticketmaster.com/*","https://www.fnactickets.com/*","https://www.rollandgarros.com/*"],"js": ["content/content.js"],"css": ["content/content.css"],"run_at": "document_start"}],"background": {"service_worker": "background/sw.js"},"commands": {"quick-add": {"suggested_key": {"default": "Alt+A"},"description": "Quick add item"},"open-sidepanel": {"suggested_key": {"default": "Ctrl+Shift+Y"},"description": "Open le Side Panel"}},"web_accessible_resources": [{"resources": ["assets/*"],"matches": ["<all_urls>"]}],"content_security_policy": {"extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"}}
