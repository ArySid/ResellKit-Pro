{
  "manifest_version": 3,
  "name": "ResellKit Bot",
  "short_name": "RKBot",
  "version": "3.0.0",
  "description": "Bot de monitoring stock/prix pour revendeurs — Nike, StockX, Ticketmaster, Roland-Garros. Alertes instantanees. 100% legal.",
  "minimum_chrome_version": "120",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ResellKit Bot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/sw.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.nike.com/*",
        "https://www.snkrs.com/*",
        "https://www.adidas.com/*",
        "https://stockx.com/*",
        "https://www.goat.com/*",
        "https://www.ticketmaster.fr/*",
        "https://www.ticketmaster.com/*",
        "https://www.fnacspectacles.com/*",
        "https://www.rollandgarros.com/*",
        "https://www.fft.fr/*",
        "https://www.leboncoin.fr/*",
        "https://www.vinted.fr/*",
        "https://www.ebay.fr/*",
        "https://www.grailed.com/*",
        "https://www.vestiairecollective.com/*",
        "https://www.footlocker.fr/*",
        "https://www.jdsports.fr/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "sidePanel",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+R"
      }
    },
    "toggle-bot": {
      "suggested_key": {
        "default": "Alt+B"
      },
      "description": "Start/Stop bot"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
